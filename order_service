from Domain.models import Order

class OrderService:
    def __init__(self, product_repo, order_repo):
        self.product_repo = product_repo
        self.order_repo = order_repo

    def create_order(self, order_items):
        """
        Expects order_items as a list of tuples: [(product_id, quantity), ...]
        Example: [(1, 2), (2, 1)]
        """
        
        # 1. Retrieve items
        # We fetch the actual product objects to ensure they exist
        products_to_order = []
        for p_id, qty in order_items:
            product = self.product_repo.get_by_id(p_id)
            if product:
                products_to_order.append((product, qty))
            else:
                raise ValueError(f"Product with ID {p_id} not found.")

        # 2. Validate orders
        # (e.g., check if there is enough stock)
        for product, qty in products_to_order:
            if product.stock < qty:
                raise ValueError(f"Not enough stock for {product.name}.")

        # 3. Create order
        # Calculate total price and instantiate the Domain Model
        new_order = Order(items=products_to_order)
        
        # 4. Save order
        self.order_repo.add(new_order)
        
        print(f"Order {new_order.id} created successfully!")
        return new_order
